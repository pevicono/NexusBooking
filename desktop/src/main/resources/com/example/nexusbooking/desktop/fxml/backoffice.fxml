<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
            fx:id="rootShell"
      fx:controller="com.example.nexusbooking.desktop.controller.BackofficeController"
      styleClass="root-pane"
      stylesheets="@../css/style.css">

        <VBox fx:id="sidebar" styleClass="sidebar" prefWidth="240" minWidth="240" maxWidth="240">
        <VBox alignment="TOP_CENTER" spacing="4">
            <Label fx:id="sidebarBrandLabel" text="NexusBooking" styleClass="sidebar-brand" alignment="CENTER" maxWidth="Infinity"/>
            <HBox alignment="CENTER" maxWidth="Infinity">
                <ImageView fx:id="sidebarFooterLogoImage" fitWidth="24" fitHeight="24" preserveRatio="true"/>
            </HBox>
        </VBox>

        <Button fx:id="navDashboardButton" text="Dashboard" styleClass="sidebar-item" maxWidth="Infinity" onAction="#showDashboardPage"/>
        <Button fx:id="navUsersButton" text="Usuaris" styleClass="sidebar-item" maxWidth="Infinity" onAction="#showUsersPage"/>
        <Button fx:id="navFacilitiesButton" text="Instal·lacions" styleClass="sidebar-item" maxWidth="Infinity" onAction="#showFacilitiesPage"/>
        <Button fx:id="navBookingsButton" text="Reserves" styleClass="sidebar-item" maxWidth="Infinity" onAction="#showBookingsPage"/>
        <Button fx:id="navGroupsButton" text="Grups" styleClass="sidebar-item" maxWidth="Infinity" onAction="#showGroupsPage"/>
        <Button fx:id="navIncidentsButton" text="Incidències" styleClass="sidebar-item" maxWidth="Infinity" onAction="#showIncidentsPage"/>
        <Button fx:id="navCalendarButton" text="Calendari" styleClass="sidebar-item" maxWidth="Infinity" onAction="#showCalendarPage"/>

        <Region VBox.vgrow="ALWAYS"/>
        <VBox alignment="BOTTOM_CENTER" spacing="6">
            <VBox fx:id="sidebarFooterMetaBox" alignment="BOTTOM_CENTER" spacing="2">
                <Label text="Backoffice" alignment="CENTER" styleClass="field-label"/>
                <Label text="v1.0.0" alignment="CENTER" styleClass="sidebar-version"/>
            </VBox>
        </VBox>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="12">
            <Button fx:id="menuToggleButton" text="" styleClass="btn-secondary,menu-toggle-button" onAction="#toggleSidebar"/>
            <Label fx:id="pageTitleLabel" text="Dashboard" styleClass="app-title-small"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="messageLabel" styleClass="success-label" maxWidth="520"/>
            <Label fx:id="currentUserLabel" text="Usuari" styleClass="current-user-pill"/>
            <Button fx:id="refreshButton" text="Refrescar" styleClass="btn-secondary" onAction="#refreshAll"/>
            <Button fx:id="logoutButton" text="Tancar sessió" styleClass="btn-danger" onAction="#logout"/>
        </HBox>

        <StackPane fx:id="pageStack" styleClass="page-stack" VBox.vgrow="ALWAYS">

            <VBox fx:id="dashboardPage" spacing="16" styleClass="content-area" maxWidth="Infinity" maxHeight="Infinity">
                <ScrollPane fitToWidth="true" styleClass="section-scroll" VBox.vgrow="ALWAYS" maxWidth="Infinity" maxHeight="Infinity">
                    <VBox spacing="16">
                        <!-- Metric Cards Row -->
                        <HBox spacing="14" alignment="TOP_LEFT">
                            <VBox styleClass="metric-card" spacing="12" HBox.hgrow="ALWAYS" alignment="TOP_CENTER">
                                <HBox alignment="CENTER">
                                    <StackPane fx:id="metricIconUsers" styleClass="metric-icon-circle,metric-icon-blue" prefWidth="70" prefHeight="70"/>
                                </HBox>
                                <Label text="Usuaris" styleClass="metric-label" alignment="CENTER"/>
                                <Label fx:id="dashboardUsersCountLabel" text="0" styleClass="metric-value" alignment="CENTER"/>
                                <Label fx:id="dashboardUsersTrendLabel" text="Inactius: 0" styleClass="metric-trend" alignment="CENTER"/>
                            </VBox>
                            <VBox styleClass="metric-card" spacing="12" HBox.hgrow="ALWAYS" alignment="TOP_CENTER">
                                <HBox alignment="CENTER">
                                    <StackPane fx:id="metricIconBookings" styleClass="metric-icon-circle,metric-icon-green" prefWidth="70" prefHeight="70"/>
                                </HBox>
                                <Label text="Reserves" styleClass="metric-label" alignment="CENTER"/>
                                <Label fx:id="dashboardBookingsCountLabel" text="0" styleClass="metric-value" alignment="CENTER"/>
                                <Label fx:id="dashboardBookingsTrendLabel" text="Completades: 0 · Pendents: 0 · Cancel·lades: 0" styleClass="metric-trend" alignment="CENTER"/>
                            </VBox>
                            <VBox styleClass="metric-card" spacing="12" HBox.hgrow="ALWAYS" alignment="TOP_CENTER">
                                <HBox alignment="CENTER">
                                    <StackPane fx:id="metricIconGroups" styleClass="metric-icon-circle,metric-icon-purple" prefWidth="70" prefHeight="70"/>
                                </HBox>
                                <Label text="Grups" styleClass="metric-label" alignment="CENTER"/>
                                <Label fx:id="dashboardGroupsCountLabel" text="0" styleClass="metric-value" alignment="CENTER"/>
                                <Label fx:id="dashboardGroupsTrendLabel" text="Amb més d'1 membre: 0" styleClass="metric-trend" alignment="CENTER"/>
                            </VBox>
                            <VBox styleClass="metric-card" spacing="12" HBox.hgrow="ALWAYS" alignment="TOP_CENTER">
                                <HBox alignment="CENTER">
                                    <StackPane fx:id="metricIconIncidents" styleClass="metric-icon-circle,metric-icon-orange" prefWidth="70" prefHeight="70"/>
                                </HBox>
                                <Label text="Incidències" styleClass="metric-label" alignment="CENTER"/>
                                <Label fx:id="dashboardIncidentsCountLabel" text="0" styleClass="metric-value" alignment="CENTER"/>
                                <Label fx:id="dashboardIncidentsTrendLabel" text="Tancades: 0" styleClass="metric-trend" alignment="CENTER"/>
                            </VBox>
                        </HBox>

                        <!-- Content Area -->
                        <HBox spacing="14" alignment="TOP_LEFT">
                            <!-- Reserves pròximes -->
                            <VBox styleClass="panel-card" spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="Reserves pròximes" styleClass="section-title"/>
                                <VBox fx:id="upcomingBookingsContainer" spacing="8"/>
                                <Button text="Veure totes les reserves" styleClass="btn-secondary" onAction="#showBookingsPage"/>
                            </VBox>

                            <!-- Activitat recent -->
                            <VBox styleClass="panel-card" spacing="10" HBox.hgrow="ALWAYS">
                                <Label text="Activitat recent" styleClass="section-title"/>
                                <VBox fx:id="recentActivityContainer" spacing="8"/>
                            </VBox>
                        </HBox>

                        <!-- Summary Row -->
                        <HBox spacing="14" alignment="TOP_LEFT">
                            <!-- Resum ràpid -->
                            <VBox styleClass="panel-card" spacing="10" HBox.hgrow="ALWAYS" prefHeight="250">
                                <Label text="Resum ràpid" styleClass="section-title"/>
                                <VBox fx:id="chartContainer" VBox.vgrow="ALWAYS" alignment="CENTER"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </ScrollPane>
            </VBox>

            <VBox fx:id="usersPage" spacing="10" styleClass="content-area" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Usuaris" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="createUserButton" text="Crear usuari" styleClass="btn-primary" onAction="#showCreateUserDialog"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="list-toolbar-row">
                    <TextField fx:id="usersSearchField" promptText="Cercar per nom, email o rol..." HBox.hgrow="ALWAYS" styleClass="list-search-field"/>
                </HBox>
                <VBox styleClass="list-surface" VBox.vgrow="ALWAYS">
                    <HBox styleClass="admin-list-header-row">
                        <Label fx:id="usersHeaderId" text="ID" styleClass="admin-list-header-cell" onMouseClicked="#sortUsersById"/>
                        <Label fx:id="usersHeaderName" text="Nom" styleClass="admin-list-header-cell" onMouseClicked="#sortUsersByName"/>
                        <Label fx:id="usersHeaderEmail" text="Email" styleClass="admin-list-header-cell" onMouseClicked="#sortUsersByEmail"/>
                        <Label fx:id="usersHeaderRole" text="Rol" styleClass="admin-list-header-cell" onMouseClicked="#sortUsersByRole"/>
                        <Label fx:id="usersHeaderStatus" text="Estat" styleClass="admin-list-header-cell" onMouseClicked="#sortUsersByStatus"/>
                        <Label fx:id="usersHeaderActions" text="Accions" styleClass="admin-list-header-cell"/>
                    </HBox>
                    <ListView fx:id="usersList" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>

            <VBox fx:id="facilitiesPage" spacing="10" styleClass="content-area" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Instal·lacions" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="createFacilityButton" text="Crear instal·lació" styleClass="btn-primary" onAction="#showCreateFacilityDialog"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="list-toolbar-row">
                    <TextField fx:id="facilitiesSearchField" promptText="Cercar per nom, tipus o ubicació..." HBox.hgrow="ALWAYS" styleClass="list-search-field"/>
                </HBox>
                <VBox styleClass="list-surface" VBox.vgrow="ALWAYS">
                    <HBox styleClass="admin-list-header-row">
                        <Label fx:id="facilitiesHeaderId" text="ID" styleClass="admin-list-header-cell" onMouseClicked="#sortFacilitiesById"/>
                        <Label fx:id="facilitiesHeaderName" text="Nom" styleClass="admin-list-header-cell" onMouseClicked="#sortFacilitiesByName"/>
                        <Label fx:id="facilitiesHeaderTypeCapacity" text="Tipus / Capacitat" styleClass="admin-list-header-cell" onMouseClicked="#sortFacilitiesByTypeCapacity"/>
                        <Label fx:id="facilitiesHeaderLocation" text="Ubicació" styleClass="admin-list-header-cell" onMouseClicked="#sortFacilitiesByLocation"/>
                        <Label fx:id="facilitiesHeaderStatus" text="Estat" styleClass="admin-list-header-cell" onMouseClicked="#sortFacilitiesByStatus"/>
                        <Label fx:id="facilitiesHeaderActions" text="Accions" styleClass="admin-list-header-cell"/>
                    </HBox>
                    <ListView fx:id="facilitiesList" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>

            <VBox fx:id="bookingsPage" spacing="10" styleClass="content-area" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Reserves" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="createBookingButton" text="Crear reserva" styleClass="btn-primary" onAction="#showCreateBookingDialog"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="list-toolbar-row">
                    <TextField fx:id="bookingsSearchField" promptText="Cercar per instal·lació, usuari o estat..." HBox.hgrow="ALWAYS" styleClass="list-search-field"/>
                </HBox>
                <VBox styleClass="list-surface" VBox.vgrow="ALWAYS">
                    <HBox styleClass="admin-list-header-row">
                        <Label fx:id="bookingsHeaderId" text="ID" styleClass="admin-list-header-cell" onMouseClicked="#sortBookingsById"/>
                        <Label fx:id="bookingsHeaderFacility" text="Instal·lació" styleClass="admin-list-header-cell" onMouseClicked="#sortBookingsByFacility"/>
                        <Label fx:id="bookingsHeaderUser" text="Usuari" styleClass="admin-list-header-cell" onMouseClicked="#sortBookingsByUser"/>
                        <Label fx:id="bookingsHeaderStart" text="Inici" styleClass="admin-list-header-cell" onMouseClicked="#sortBookingsByStart"/>
                        <Label fx:id="bookingsHeaderStatus" text="Estat" styleClass="admin-list-header-cell" onMouseClicked="#sortBookingsByStatus"/>
                        <Label fx:id="bookingsHeaderActions" text="Accions" styleClass="admin-list-header-cell"/>
                    </HBox>
                    <ListView fx:id="bookingsList" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>

            <VBox fx:id="incidentsPage" spacing="10" styleClass="content-area" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Incidències" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="createIncidentButton" text="Crear incidència" styleClass="btn-primary" onAction="#showCreateIncidentDialog"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="list-toolbar-row">
                    <TextField fx:id="incidentsSearchField" promptText="Cercar per títol, instal·lació o estat..." HBox.hgrow="ALWAYS" styleClass="list-search-field"/>
                </HBox>
                <VBox styleClass="list-surface" VBox.vgrow="ALWAYS">
                    <HBox styleClass="admin-list-header-row">
                        <Label fx:id="incidentsHeaderId" text="ID" styleClass="admin-list-header-cell" onMouseClicked="#sortIncidentsById"/>
                        <Label fx:id="incidentsHeaderTitle" text="Títol" styleClass="admin-list-header-cell" onMouseClicked="#sortIncidentsByTitle"/>
                        <Label fx:id="incidentsHeaderFacility" text="Instal·lació" styleClass="admin-list-header-cell" onMouseClicked="#sortIncidentsByFacility"/>
                        <Label fx:id="incidentsHeaderDate" text="Data" styleClass="admin-list-header-cell" onMouseClicked="#sortIncidentsByDate"/>
                        <Label fx:id="incidentsHeaderStatus" text="Estat" styleClass="admin-list-header-cell" onMouseClicked="#sortIncidentsByStatus"/>
                        <Label fx:id="incidentsHeaderActions" text="Accions" styleClass="admin-list-header-cell"/>
                    </HBox>
                    <ListView fx:id="incidentsList" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>

            <VBox fx:id="groupsPage" spacing="10" styleClass="content-area" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Grups" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="createAdminGroupButton" text="Crear grup" styleClass="btn-primary" onAction="#showCreateGroupDialog"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT" styleClass="list-toolbar-row">
                    <TextField fx:id="groupsSearchField" promptText="Cercar per nom, propietari o codi..." HBox.hgrow="ALWAYS" styleClass="list-search-field"/>
                </HBox>
                <VBox styleClass="list-surface" VBox.vgrow="ALWAYS">
                    <HBox styleClass="admin-list-header-row">
                        <Label fx:id="groupsHeaderId" text="ID" styleClass="admin-list-header-cell" onMouseClicked="#sortGroupsById"/>
                        <Label fx:id="groupsHeaderName" text="Nom" styleClass="admin-list-header-cell" onMouseClicked="#sortGroupsByName"/>
                        <Label fx:id="groupsHeaderOwner" text="Propietari" styleClass="admin-list-header-cell" onMouseClicked="#sortGroupsByOwner"/>
                        <Label fx:id="groupsHeaderMembers" text="Membres" styleClass="admin-list-header-cell" onMouseClicked="#sortGroupsByMembers"/>
                        <Label fx:id="groupsHeaderCode" text="Codi" styleClass="admin-list-header-cell" onMouseClicked="#sortGroupsByCode"/>
                        <Label fx:id="groupsHeaderActions" text="Accions" styleClass="admin-list-header-cell"/>
                    </HBox>
                    <ListView fx:id="groupsList" VBox.vgrow="ALWAYS"/>
                </VBox>
            </VBox>

            <VBox fx:id="calendarPage" spacing="10" styleClass="content-area" maxWidth="Infinity" maxHeight="Infinity">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Calendari" styleClass="section-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="◀" onAction="#calendarPrevMonth" styleClass="btn-secondary"/>
                    <Label fx:id="calendarMonthLabel" styleClass="app-title-small" alignment="CENTER" prefWidth="170" minWidth="170"/>
                    <Button text="▶" onAction="#calendarNextMonth" styleClass="btn-secondary"/>
                    <Label text="Any:" styleClass="field-label"/>
                    <ComboBox fx:id="calendarYearCombo" prefWidth="110" onAction="#calendarYearChanged"/>
                    <Label text="Instal·lació:" styleClass="field-label"/>
                    <ComboBox fx:id="calendarFacilityCombo" prefWidth="200" onAction="#refreshCalendarView"/>
                </HBox>
                <ScrollPane fitToHeight="false" fitToWidth="false" pannable="true" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER" VBox.vgrow="ALWAYS" styleClass="section-scroll">
                    <GridPane fx:id="calendarGrid" hgap="1" vgap="1" styleClass="calendar-grid"/>
                </ScrollPane>
            </VBox>
        </StackPane>
    </VBox>
</HBox>
